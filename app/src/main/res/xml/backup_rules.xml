<?xml version="1.0" encoding="utf-8"?><!--
   Legacy Auto Backup rules, used on API 23-30 (data_extraction_rules.xml covers API 31+).
   See https://developer.android.com/guide/topics/data/autobackup for details.

   Same exclusions as data_extraction_rules.xml and for the same reason: the Android Keystore
   key that decrypts the passphrase blob never leaves the original device, so restoring the
   encrypted database or the blob without it would leave a database that can never be opened
   (see docs/DB_ENCRYPTION.md, "Unrecoverable key failure").
-->
<full-backup-content>
    <exclude domain="database" path="tempo_database"/>
    <exclude domain="database" path="tempo_database-wal"/>
    <exclude domain="database" path="tempo_database-shm"/>
    <exclude domain="sharedpref" path="tempo_secure_prefs.xml"/>
</full-backup-content>